{
  "name": "miit-delivery-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:vite": "tsc -b && vite build",
    "build": "npm run build:vite && node scripts/prepare-hosting.mjs",
    "build:cloudflare": "npm run build:vite",
    "deploy:cloudflare": "npm run build:cloudflare && wrangler deploy",
    "preview": "vite preview",
    "check": "tsc -b --pretty false",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:pi": "python -m unittest discover -s robot-pi -p \"test_*.py\" -v",
    "test:esp32": "python -m unittest discover -s MIIT_Rover_ESP32_Firmware_v0.2.0/robot-esp32/tests -p \"test_*.py\" -v",
    "test:db": "supabase test db --local supabase/tests/database",
    "test:emqx-publish": "node --test supabase/tests/integration/emqx-publish-response.test.mjs",
    "test:emqx-contract": "node --test --test-concurrency=1 supabase/tests/integration/ingest-robot-message.test.mjs",
    "test:integration": "node scripts/run-supabase-integration.mjs",
    "lint:db": "supabase db lint --local --schema public --level error --fail-on error"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.53.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.1.1"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^26.1.0",
    "supabase": "^2.109.1",
    "typescript": "~5.7.2",
    "vite": "^6.0.5",
    "vitest": "^3.2.7",
    "wrangler": "^4.111.0"
  }
}
